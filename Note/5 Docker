[ec2-user@ip-172-31-6-170 poc-nextjs]$ cat Dockerfile
FROM node:latest

RUN mkdir -p /usr/src/app
WORKDIR /usr/src/app

# copying all the files from your file system to container file system
COPY package.json .

# install all dependencies
RUN npm install

# copy oter files as well
COPY ./ .

RUN npm run build

#expose the port
EXPOSE 3000

# command to run when intantiate an image
CMD ["npm","run","start"]

